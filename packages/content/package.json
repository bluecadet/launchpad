{
  "name": "@bluecadet/launchpad-content",
  "version": "2.3.0",
  "description": "Content syncing pipeline for various sources",
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "static/**/*"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./launchpad-content": {
      "types": "./dist/launchpad-content.d.ts",
      "default": "./dist/launchpad-content.js"
    },
    "./commands": {
      "types": "./dist/content-commands.d.ts",
      "default": "./dist/content-commands.js"
    },
    "./config": {
      "types": "./dist/content-config.d.ts",
      "default": "./dist/content-config.js"
    },
    "./events": {
      "types": "./dist/content-events.d.ts",
      "default": "./dist/content-events.js"
    },
    "./state": {
      "types": "./dist/content-state.d.ts",
      "default": "./dist/content-state.js"
    },
    "./plugin": {
      "types": "./dist/content-plugin.d.ts",
      "default": "./dist/content-plugin.js"
    },
    "./plugins": {
      "types": "./dist/plugins/index.d.ts",
      "default": "./dist/plugins/index.js"
    },
    "./plugins/md-to-html": {
      "types": "./dist/plugins/md-to-html.d.ts",
      "default": "./dist/plugins/md-to-html.js"
    },
    "./plugins/media-downloader": {
      "types": "./dist/plugins/media-downloader.d.ts",
      "default": "./dist/plugins/media-downloader.js"
    },
    "./plugins/sanity-image-url-transform": {
      "types": "./dist/plugins/sanity-image-url-transform.d.ts",
      "default": "./dist/plugins/sanity-image-url-transform.js"
    },
    "./plugins/sanity-to-html": {
      "types": "./dist/plugins/sanity-to-html.d.ts",
      "default": "./dist/plugins/sanity-to-html.js"
    },
    "./plugins/sanity-to-markdown": {
      "types": "./dist/plugins/sanity-to-markdown.d.ts",
      "default": "./dist/plugins/sanity-to-markdown.js"
    },
    "./plugins/sanity-to-plain": {
      "types": "./dist/plugins/sanity-to-plain.d.ts",
      "default": "./dist/plugins/sanity-to-plain.js"
    },
    "./plugins/sharp": {
      "types": "./dist/plugins/sharp.d.ts",
      "default": "./dist/plugins/sharp.js"
    },
    "./plugins/symlink": {
      "types": "./dist/plugins/symlink.d.ts",
      "default": "./dist/plugins/symlink.js"
    },
    "./source": {
      "types": "./dist/source.d.ts",
      "default": "./dist/source.js"
    },
    "./sources": {
      "types": "./dist/sources/index.d.ts",
      "default": "./dist/sources/index.js"
    },
    "./sources/airtable": {
      "types": "./dist/sources/airtable-source.d.ts",
      "default": "./dist/sources/airtable-source.js"
    },
    "./sources/contentful": {
      "types": "./dist/sources/contentful-source.d.ts",
      "default": "./dist/sources/contentful-source.js"
    },
    "./sources/json": {
      "types": "./dist/sources/json-source.d.ts",
      "default": "./dist/sources/json-source.js"
    },
    "./sources/sanity": {
      "types": "./dist/sources/sanity-source.d.ts",
      "default": "./dist/sources/sanity-source.js"
    },
    "./sources/strapi": {
      "types": "./dist/sources/strapi-source.d.ts",
      "default": "./dist/sources/strapi-source.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluecadet/launchpad.git"
  },
  "engines": {
    "node": ">=18"
  },
  "author": "Bluecadet",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bluecadet/launchpad/issues"
  },
  "homepage": "https://github.com/bluecadet/launchpad/packages/content",
  "dependencies": {
    "@bluecadet/launchpad-monitor": "^2.1.0",
    "@bluecadet/launchpad-utils": "~2.1.0",
    "chalk": "^5.0.0",
    "glob": "^11.0.0",
    "h3": "^2.0.1-rc.6",
    "immer": "^10.2.0",
    "jsonpath-plus": "^10.3.0",
    "ky": "^1.7.2",
    "markdown-it": "^14.1.0",
    "neverthrow": "^8.1.1",
    "p-queue": "^7.1.0",
    "qs": "^6.11.1",
    "sanitize-html": "^2.5.1",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@portabletext/to-html": "2.0.0",
    "@sanity/block-content-to-markdown": "^0.0.5",
    "@sanity/client": "^6.4.9",
    "@sanity/image-url": "^1.1.0",
    "airtable": "^0.11.1",
    "contentful": "^9.0.0",
    "sharp": "^0.33.5"
  },
  "peerDependenciesMeta": {
    "@portabletext/to-html": {
      "optional": true
    },
    "@sanity/block-content-to-markdown": {
      "optional": true
    },
    "@sanity/client": {
      "optional": true
    },
    "@sanity/image-url": {
      "optional": true
    },
    "airtable": {
      "optional": true
    },
    "contentful": {
      "optional": true
    },
    "sharp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@bluecadet/launchpad-testing": "0.1.0",
    "@bluecadet/launchpad-tsconfig": "0.1.0",
    "@portabletext/to-html": "2.0.0",
    "@sanity/block-content-to-markdown": "^0.0.5",
    "@sanity/client": "^6.4.9",
    "@sanity/image-url": "^1.1.0",
    "@types/markdown-it": "^14.1.2",
    "@types/qs": "^6.9.7",
    "@types/sanitize-html": "^2.9.0",
    "airtable": "^0.11.1",
    "contentful": "^9.0.0",
    "memfs": "^4.14.0",
    "msw": "^2.6.6",
    "sharp": "^0.33.5",
    "vitest": "^3.0.7"
  }
}
