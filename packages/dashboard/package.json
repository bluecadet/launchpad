{
  "name": "@bluecadet/launchpad-dashboard",
  "version": "2.0.0",
  "description": "Dashboard UI plugin for Launchpad",
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./launchpad-dashboard": {
      "types": "./dist/launchpad-dashboard.d.ts",
      "default": "./dist/launchpad-dashboard.js"
    },
    "./panel": {
      "types": "./dist/dashboard-panel.d.ts",
      "default": "./dist/dashboard-panel.js"
    },
    "./page": {
      "types": "./dist/dashboard-page.d.ts",
      "default": "./dist/dashboard-page.js"
    },
    "./config": {
      "types": "./dist/dashboard-config.d.ts",
      "default": "./dist/dashboard-config.js"
    },
    "./state": {
      "types": "./dist/dashboard-state.d.ts",
      "default": "./dist/dashboard-state.js"
    },
    "./commands": {
      "types": "./dist/dashboard-commands.d.ts",
      "default": "./dist/dashboard-commands.js"
    },
    "./events": {
      "types": "./dist/dashboard-events.d.ts",
      "default": "./dist/dashboard-events.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "default": "./dist/ui/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "test": "vitest"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluecadet/launchpad.git"
  },
  "author": "Bluecadet",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bluecadet/launchpad/issues"
  },
  "homepage": "https://github.com/bluecadet/launchpad/packages/dashboard",
  "dependencies": {
    "@bluecadet/launchpad-utils": "~2.1.0",
    "h3": "^1.15.3",
    "neverthrow": "^8.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bluecadet/launchpad-testing": "0.1.0",
    "@bluecadet/launchpad-tsconfig": "0.1.0",
    "vitest": "^4.1.2"
  }
}
