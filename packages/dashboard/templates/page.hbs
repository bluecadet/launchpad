<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{title}}</title>
  {{#each cssFiles}}
  <link rel="stylesheet" href="{{this}}" />
  {{/each}}
</head>

<body>
  {{!-- header --}}
  <header class="dashboard-header">
    {{!-- only if we have more than one page --}}
    {{#if pages.[1]}}
    <nav class="dashboard-nav">
      <ul>
        {{#each pages}}
        <li><a href="/{{this.slug}}">{{this.title}}</a></li>
        {{/each}}
      </ul>
    </nav>
    {{/if}}
  </header>
  {{!-- body --}}
  {{#if content.raw}}
  {{{content.raw}}}
  {{else}}
  <div class="dashboard-panels">
    {{#each content.panels}}
    <div class="dashboard-panel">
      <h2>{{this.title}}</h2>
      <div class="dashboard-panel-content">
        {{{this.content}}}
      </div>
    </div>
    {{/each}}
  </div>
  {{/if}}
  {{#each jsFiles}}
  <script src="{{this}}"></script>
  {{/each}}
</body>

</html>