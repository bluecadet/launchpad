{{!-- only show if we have more than 1 app --}}
{{#ifMultiple apps}}
<div class="panel-section monitor-overview">
  <p>Status:</p>{{#if isConnected}}<span class="badge success">connected</span>{{else}}<span
    class="badge neutral">disconnected</span>{{/if}}
  {{#if isConnected}}
  <button class="button warning" hx-post="/api/monitor/action" hx-vals='{"action":"restart"}' hx-swap="none">Restart
    All</button>
  <button class="button danger" hx-post="/api/monitor/action" hx-vals='{"action":"stop"}' hx-swap="none">Stop
    All</button>
  {{/if}}
</div>
{{/ifMultiple}}
<div class="panel-section">
  {{#each apps}}
  <div class="monitor-app {{name}}">
    <h3>{{name}}</h3>
    <p class="badge {{appStatusToThemeVar status}}">{{status}}</p>
    {{#if ../isConnected}}
    {{#if action}}
    <svg width="24" height="24" viewBox="0 0 24 24" class="spinner">
      <path
        d="M10.14,1.16a11,11,0,0,0-9,8.92A1.59,1.59,0,0,0,2.46,12,1.52,1.52,0,0,0,4.11,10.7a8,8,0,0,1,6.66-6.61A1.42,1.42,0,0,0,12,2.69h0A1.57,1.57,0,0,0,10.14,1.16Z"
        class="spinner-inner" />
    </svg>
    {{/if}}
    {{#ifMatch status "offline"}}
    <button class="button success" hx-post="/api/monitor/action" hx-vals='{"action":"start","appName":"{{name}}"}' {{#if
      action}}disabled{{/if}} hx-swap="none">Start</button>
    {{else}}
    <button class="button warning" hx-post="/api/monitor/action" hx-vals='{"action":"restart","appName":"{{name}}"}'
      {{#if action}}disabled{{/if}} hx-swap="none">Restart</button>
    <button class="button danger" hx-post="/api/monitor/action" hx-vals='{"action":"stop","appName":"{{name}}"}' {{#if
      action}}disabled{{/if}} hx-swap="none">Stop</button>
    {{/ifMatch}}
    {{/if}}
  </div>
  {{/each}}
</div>