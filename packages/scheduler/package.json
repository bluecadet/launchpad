{
  "name": "@bluecadet/launchpad-scheduler",
  "version": "2.0.0",
  "description": "Generic command scheduler plugin for Launchpad",
  "type": "module",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./launchpad-scheduler": {
      "types": "./dist/launchpad-scheduler.d.ts",
      "default": "./dist/launchpad-scheduler.js"
    },
    "./config": {
      "types": "./dist/scheduler-config.d.ts",
      "default": "./dist/scheduler-config.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "test": "vitest"
  },
  "engines": {
    "node": ">=23"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluecadet/launchpad.git"
  },
  "author": "Bluecadet",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bluecadet/launchpad/issues"
  },
  "homepage": "https://github.com/bluecadet/launchpad/packages/scheduler",
  "dependencies": {
    "@bluecadet/launchpad-utils": "~3.0.0",
    "croner": "^10.0.1",
    "neverthrow": "^8.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@bluecadet/launchpad-testing": "0.1.0",
    "@bluecadet/launchpad-tsconfig": "0.1.0",
    "vitest": "^4.1.2"
  }
}
