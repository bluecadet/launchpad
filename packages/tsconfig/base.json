{
	"compilerOptions": {
		"esModuleInterop": true,
		"skipLibCheck": true,
		"target": "es2025",
		"allowJs": true,
		"resolveJsonModule": true,
		"moduleDetection": "force",
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"strict": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true,
		"module": "NodeNext",
		"outDir": "${configDir}/dist",
		"rootDir": "${configDir}/src",
		"sourceMap": true,
		"declaration": true,
		"composite": true,
		"declarationMap": true,
		"lib": ["es2025"],
		"types": ["node"],
		"tsBuildInfoFile": "${configDir}/dist/tsconfig.src.tsbuildinfo"
	},
	"include": [
		"${configDir}/src/**/*.ts"
	],
	"exclude": [
		"${configDir}/**/*.test.ts",
		"${configDir}/**/__tests__/*"
	]
}
