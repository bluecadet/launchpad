    "chalk": "^5.0.0",
    "moment": "^2.29.1",
    "neverthrow": "^8.1.0",
    "winston": "^3.4.0",
    "winston-daily-rotate-file": "^4.5.5"
  },
  "homepage": "https://github.com/bluecadet/launchpad/packages/utils",
  "devDependencies": {
    "@bluecadet/launchpad-tsconfig": "0.1.0",
    "@bluecadet/launchpad-testing": "0.1.0",
    "@types/node": "^20.3.1",
    "@types/winston": "^2.4.4",
    "typescript": "^5.1.3",
    "vitest": "^2.1.4"
