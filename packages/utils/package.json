{
  "name": "@bluecadet/launchpad-utils",
  "version": "2.1.0",
  "description": "Common utilities used by multiple launchpad modules",
  "type": "module",
  "exports": {
    "./console-transport": {
      "types": "./dist/console-transport.d.ts",
      "default": "./dist/console-transport.js"
    },
    "./log-manager": {
      "types": "./dist/log-manager.d.ts",
      "default": "./dist/log-manager.js"
    },
    "./plugin-driver": {
      "types": "./dist/plugin-driver.d.ts",
      "default": "./dist/plugin-driver.js"
    },
    "./state-patcher": {
      "types": "./dist/state-patcher.d.ts",
      "default": "./dist/state-patcher.js"
    },
    "./controller-interfaces": {
      "types": "./dist/controller-interfaces.d.ts",
      "default": "./dist/controller-interfaces.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./on-exit": {
      "types": "./dist/on-exit.d.ts",
      "default": "./dist/on-exit.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluecadet/launchpad.git"
  },
  "author": "Bluecadet",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bluecadet/launchpad/issues"
  },
  "dependencies": {
    "@sindresorhus/slugify": "^2.1.0",
    "ansi-escapes": "^7.1.1",
    "chalk": "^5.0.0",
    "immer": "^10.2.0",
    "moment": "^2.29.1",
    "neverthrow": "^8.1.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^4.5.5",
    "zod": "^3.23.8"
  },
  "homepage": "https://github.com/bluecadet/launchpad/packages/utils",
  "devDependencies": {
    "@bluecadet/launchpad-testing": "0.1.0",
    "@bluecadet/launchpad-tsconfig": "0.1.0",
    "vitest": "^3.0.7"
  }
}
