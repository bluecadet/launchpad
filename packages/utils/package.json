{
  "name": "@bluecadet/launchpad-utils",
  "version": "2.1.0",
  "description": "Common utilities used by multiple launchpad modules",
  "type": "module",
  "exports": {
    "./logger": {
      "types": "./dist/logger.d.ts",
      "default": "./dist/logger.js"
    },
    "./fixed-tty-logger": {
      "types": "./dist/fixed-tty-logger.d.ts",
      "default": "./dist/fixed-tty-logger.js"
    },
    "./plugin-driver": {
      "types": "./dist/plugin-driver.d.ts",
      "default": "./dist/plugin-driver.js"
    },
    "./state-patcher": {
      "types": "./dist/state-patcher.d.ts",
      "default": "./dist/state-patcher.js"
    },
    "./subsystem-interfaces": {
      "types": "./dist/subsystem-interfaces.d.ts",
      "default": "./dist/subsystem-interfaces.js"
    },
    "./event-bus": {
      "types": "./dist/event-bus.d.ts",
      "default": "./dist/event-bus.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "default": "./dist/types.js"
    },
    "./on-exit": {
      "types": "./dist/on-exit.d.ts",
      "default": "./dist/on-exit.js"
    },
    "./command-guard": {
      "types": "./dist/command-guard.d.ts",
      "default": "./dist/command-guard.js"
    }
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bluecadet/launchpad.git"
  },
  "author": "Bluecadet",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/bluecadet/launchpad/issues"
  },
  "dependencies": {
    "chalk": "^5.0.0",
    "immer": "^10.2.0",
    "neverthrow": "^8.1.1"
  },
  "homepage": "https://github.com/bluecadet/launchpad/packages/utils",
  "devDependencies": {
    "@bluecadet/launchpad-testing": "0.1.0",
    "@bluecadet/launchpad-tsconfig": "0.1.0",
    "vitest": "^3.0.7"
  }
}
